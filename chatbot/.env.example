# Copy this file to .env and fill in your values.
# Never commit .env to git.

OPENAI_API_KEY=your_openai_api_key_here

# Model settings (defaults shown — change to any OpenAI model name)
LLM_MODEL=gpt-4o-mini
EMBED_MODEL=text-embedding-3-small
TEMPERATURE=0.1

# Retrieval settings
TOP_K=3
SIMILARITY_THRESHOLD=0.20

# Chunking settings (in tokens). Smaller chunks = cleaner topical separation
# for dense FAQ/help docs; larger chunks keep more context together.
CHUNK_SIZE=256
CHUNK_OVERLAP=32

# Storage paths (relative to where you run cli.py)
SOURCE_DOCS_DIR=data/source_docs
CHROMA_STORE_DIR=data/chroma_store
CHROMA_COLLECTION=knowledge_base
